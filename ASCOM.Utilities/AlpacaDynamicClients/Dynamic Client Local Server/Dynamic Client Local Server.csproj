<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <ProductVersion>net8.0.50727</ProductVersion>
    <OutputType>WinExe</OutputType>
    <AssemblyName>DynamicClientServer</AssemblyName>
    <TargetFramework>net8.0-windows10.0.26100.0</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <AssemblyTitle>Alpaca Dynamic Client Manager</AssemblyTitle>
    <Product>ASCOM.DynamicClientLocalServer</Product>
    <Copyright>Copyright © ASCOM Initiative 2024</Copyright>
    <AssemblyVersion>7.0.0.0</AssemblyVersion>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <OutputPath>bin\$(Configuration)\</OutputPath>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugType>embedded</DebugType>
    <CodeAnalysisRuleSet>MinimumRecommendedRules.ruleset</CodeAnalysisRuleSet>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>embedded</DebugType>
    <Optimize>False</Optimize>
  </PropertyGroup>
  <PropertyGroup>
    <SignAssembly>true</SignAssembly>
  </PropertyGroup>
  <PropertyGroup>
    <AssemblyOriginatorKeyFile>LocalServer.snk</AssemblyOriginatorKeyFile>
  </PropertyGroup>
  <PropertyGroup>
    <PreBuildEvent />
    <PostBuildEvent />
    <RootNamespace>ASCOM.DynamicClients</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Update="LocalServerForm.resx">
      <SubType>Designer</SubType>
      <DependentUpon>LocalServerForm.cs</DependentUpon>
    </EmbeddedResource>
  </ItemGroup>
  <ItemGroup>
    <Content Include="ASCOM.ico" />
    <Content Include="ASCOM.png" />
  </ItemGroup>
  <ItemGroup>
    <None Include="LocalServer.snk" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="ASCOM.Alpaca.Components" Version="2.0.1" />
    <PackageReference Include="ASCOM.Com.Components" Version="2.0.1" />
    <PackageReference Include="ASCOM.Common.Components" Version="2.0.1" />
    <PackageReference Include="ASCOM.Tools" Version="2.0.1" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\ASCOM.DeviceInterface\ASCOM.DeviceInterface.csproj" />
    <ProjectReference Include="..\..\..\ASCOM.Exceptions\ASCOM.Exceptions.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Reference Include="System.Security" />
  </ItemGroup>
</Project>